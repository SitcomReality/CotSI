<div class="modal" id="confirmModal">
  <div class="confirm-card">
    <h2 class="confirm-title" id="confirmTitle">Confirm</h2>
    <p class="confirm-body mini" id="confirmBody">—</p>
    <div class="confirm-actions">
      <button class="btn-gold confirm-btn confirm-btn--yes" data-action="confirmYes" id="confirmYesBtn">Yes</button>
      <button class="confirm-btn confirm-btn--no" data-action="confirmNo">No</button>
    </div>
  </div>
</div>
