<div class="modal" id="deathModal">
  <div class="death-modal-card" id="deathCard">
    <div class="death-modal-header">
      <div class="death-modal__kicker">A Champion Has Fallen</div>
      <div class="death-modal__title" id="deathTitle"></div>
    </div>
    <div class="death-modal-body" id="deathBody"></div>
    <button class="btn-gold death-modal-btn" id="deathAck" data-action="acknowledgeDeath">Continue</button>
  </div>
</div>
